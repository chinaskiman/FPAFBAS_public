# Required security settings
ADMIN_TOKEN=change-me-with-a-long-random-token

# Telegram notifications (optional if disabled)
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Runtime storage
DATA_DIR=/data
SQLITE_PATH=/data/app.db
WATCHLIST_PATH=/data/watchlist.json
POLLER_LOCK_PATH=/data/poller.lock

# Runtime tuning
POLL_SECONDS=15
POLLER_START_PAUSED=false
CACHE_MAXLEN=1200
LOG_LEVEL=INFO

# API/browser access
CORS_ORIGINS=https://example.com

# Journal
JOURNAL_DB_URL=
JOURNAL_INTRACANDLE_MODEL=worst_case

# Forward test (paper trading)
FT_STARTING_EQUITY=10000
FT_LEVERAGE=20
FT_RISK_PCT=0.01
FT_MAX_POSITIONS=3
FT_FEE_RATE=0.001
FT_TP_R=2.0
FT_CANCEL_AFTER_CANDLES=3
FT_RISK_FREE_RATE=0.02
FT_TIMEZONE=Europe/Berlin

# VPS TLS (used by deploy/Caddyfile)
DOMAIN=example.com
ACME_EMAIL=admin@example.com
